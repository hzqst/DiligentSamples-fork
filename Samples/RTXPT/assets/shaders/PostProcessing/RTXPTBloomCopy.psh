SamplerState      s_LinearSampler;
Texture2D<float4> t_Source;

struct PSInput
{
    float4 Pos : SV_POSITION;
    float2 UV  : TEX_COORD;
};

struct PSOutput
{
    float4 Color : SV_TARGET;
};

void main(in PSInput Input,
          out PSOutput Output)
{
    Output.Color = t_Source.SampleLevel(s_LinearSampler, Input.UV, 0.0);
}
